@app.route('/', methods=['GET', 'POST'])
def login_usuario():
    erro = None
    if request.method == 'POST':
        username = request.form.get('username', '').strip()
        if username in BANCO_USUARIOS_MEMORIA:
            session['usuario_em_verificacao'] = username
            return redirect(url_for('login_senha'))
        erro = "Operador não localizado no sistema."
    return render_template_string(PAGINA_LOGIN_USUARIO, erro=erro)

@app.route('/senha', methods=['GET', 'POST'])
def login_senha():
    usuario_temporario = session.get('usuario_em_verificacao')
    if not usuario_temporario: 
        return redirect(url_for('login_usuario'))
    
    erro = None
    if request.method == 'POST':
        password = request.form.get('password', '')
        dados_usuario = BANCO_USUARIOS_MEMORIA.get(usuario_temporario)
        
        if dados_usuario and check_password_hash(dados_usuario['senha'], password):
            session.pop('usuario_em_verificacao', None)
            session['usuario'] = usuario_temporario
            session['cargo'] = dados_usuario['nivel']
            return redirect(url_for('dashboard'))
        erro = "Chave de acesso incorreta!"
        
    return render_template_string(PAGINA_LOGIN_SENHA, erro=erro, usuario=usuario_temporario)

@app.route('/cadastro', methods=['GET', 'POST'])
def cadastro():
    erro = None
    sucesso = None
    if request.method == 'POST':
        username = request.form.get('username', '').strip()
        email = request.form.get('email', '').strip()
        password = request.form.get('password', '')
        confirm_password = request.form.get('confirm_password', '')
        nivel_acesso = request.form.get('nivel_acesso', 'Visitante')

        if username in BANCO_USUARIOS_MEMORIA:
            erro = "Este nome de operador já está em uso."
        elif password != confirm_password:
            erro = "As senhas informadas não coincidem!"
        else:
            # Segurança avançada: Criptografa a senha antes de salvar na memória
            BANCO_USUARIOS_MEMORIA[username] = {
                "email": email,
                "senha": generate_password_hash(password),
                "nivel": nivel_acesso
            }
            sucesso = "Conta de operador criada! Redirecionando..."
            
    return render_template_string(PAGINA_CADASTRO, erro=erro, success=sucesso)

