# ===================================================
# 🛰️ FUNÇÃO DE DISPARO PARA O GOOGLE SHEETS
# ===================================================
def salvar_no_google_sheets(temperatura, umidade, status_alarme):
    try:
        escopos = ["https://spreadsheets.google.com/feeds", "https://www.googleapis.com/auth/drive"]
        creds = ServiceAccountCredentials.from_json_keyfile_dict(CREDENCIAIS_GOOGLE, escopos)
        cliente = gspread.authorize(creds)
        
        planilha = cliente.open(NOME_DA_PLANILHA).sheet1
        agora = datetime.now().strftime('%d/%m/%Y %H:%M:%S')
        
        # Estrutura idêntica às colunas da sua imagem: Temperatura, Umidade, Data_Hora, Status
        nova_linha = [temperatura, umidade, agora, status_alarme]
        
        planilha.append_row(nova_linha)
        print(f"[GOOGLE SHEETS] Dados gravados na nuvem: {nova_linha}")
    except Exception as e:
        print(f"[ERRO GOOGLE] Falha ao enviar para a planilha: {e}")

# ===================================================
# 💻 THREAD DE ESCUTA DA PORTA SERIAL DO ARDUINO
# ===================================================
def escutar_leitura_serial():
    global ultimo_registro_local
    portas_para_testar = ['COM7', 'COM8', 'COM3', 'COM4']
    
    while True:
        ser = None
        porta_ativa = None
        
        for porta in portas_para_testar:
            try:
                ser = serial.Serial(porta, BAUD_RATE, timeout=1)
                porta_ativa = porta
                break 
            except Exception:
                continue 
        
        if ser and porta_ativa:
            print(f"[SERIAL] Conexão estabelecida com sucesso na porta {porta_ativa}!")
            try:
                while True:
                    if ser.in_waiting > 0:
                        linha = ser.readline().decode('utf-8', errors='ignore').strip()
                        if len(linha) > 0:
                            linha_limpa = ''.join(c for c in linha if c.isdigit() or c == '.')
                            try:
                                valor_temperatura = float(linha_limpa)
                                print(f"[DADO USB] Recebido: {valor_temperatura}°C")
                                
                                valor_umidade = 65  # Média padrão para o DHT11
                                status_sistema = "Normal" if valor_temperatura < 35.0 else "Crítico"
                                
                                ultimo_registro_local = {
                                    "temp": f"{valor_temperatura:.1f}",
                                    "umid": str(valor_umidade),
                                    "status": status_sistema
                                }
                                
                                # Salva na planilha de forma assíncrona
                                salvar_no_google_sheets(valor_temperatura, valor_umidade, status_sistema)
                                
                            except ValueError:
                                pass
                    time.sleep(0.1)
            except Exception as e:
                print(f"[AVISO HARDWARE] Conexão perdida na porta {porta_ativa}. Reconectando...")
            finally:
                if ser: ser.close()
        else:
            print("[AVISO HARDWARE] Nenhuma placa encontrada. Tentando em 3s...")
            time.sleep(3)

