@app.route('/', methods=['GET', 'POST'])
def login_usuario():
    erro = None
    if request.method == 'POST':
        username = request.form.get('username', '').strip()
        try:
            conn = conectar_mysql()
            with conn.cursor() as cursor:
                cursor.execute("SELECT usuario FROM usuarios WHERE usuario = %s", (username,))
                row = cursor.fetchone()
            conn.close()
            
            if row:
                session['usuario_em_verificacao'] = row['usuario']
                return redirect(url_for('login_senha'))
            
            erro = "Operador não cadastrado na base AlphaTech."
        except Exception as e: 
            erro = f"Erro de banco: {e}"
    return render_template_string(PAGINA_USUARIO, erro=erro)

@app.route('/senha', methods=['GET', 'POST'])
def login_senha():
    usuario_temporario = session.get('usuario_em_verificacao')
    if not usuario_temporario: 
        return redirect(url_for('login_usuario'))
    erro = None
    if request.method == 'POST':
        password = request.form.get('password', '')
        try:
            conn = conectar_mysql()
            with conn.cursor() as cursor:
                cursor.execute("SELECT usuario, senha_hash, nivel_acesso FROM usuarios WHERE usuario = %s", (usuario_temporario,))
                row = cursor.fetchone()
            conn.close()
            
            if row and check_password_hash(row['senha_hash'], password):
                session.pop('usuario_em_verificacao', None)
                session['usuario'] = row['usuario']
                session['regime'] = row['nivel_acesso']
                return redirect(url_for('dashboard'))
            erro = "Chave de acesso incorreta!"
        except Exception as e: 
            erro = f"Erro: {e}"
    return render_template_string(PAGINA_SENHA, erro=erro, usuario=usuario_temporario)

@app.route('/cadastro', methods=['GET', 'POST'])
def cadastro():
    erro = None
    sucesso = None
    if request.method == 'POST':
        username = request.form.get('username', '').strip()
        email = request.form.get('email', '').strip()
        password = request.form.get('password', '')
        confirm_password = request.form.get('confirm_password', '')
        nivel_acesso = request.form.get('nivel_acesso', 'Visitante')

        if password != confirm_password:
            erro = "As senhas não coincidem!"
        else:
            try:
                conn = conectar_mysql()
                with conn.cursor() as cursor:
                    cursor.execute("SELECT id_usuario FROM usuarios WHERE usuario = %s", (username,))
                    if cursor.fetchone():
                        erro = "Este nome de operador já existe!"
                    else:
                        senha_criptografada = generate_password_hash(password)
                        cursor.execute(
                            "INSERT INTO usuarios (usuario, email, senha_hash, nivel_acesso) VALUES (%s, %s, %s, %s)",
                            (username, email, senha_criptografada, nivel_acesso)
                        )
                        conn.commit()
                        sucesso = "Operador criado com sucesso! Redirecionando..."
                conn.close()
            except Exception as e:
                erro = f"Erro ao salvar: {e}"

    return render_template_string(PAGINA_CADASTRO, erro=erro, success=sucesso)

@app.route('/dashboard')
def dashboard():
    if 'usuario' not in session: 
        return redirect(url_for('login_usuario'))
    
    historico = []
    ultima_leitura = {"sensor": "Aguardando Arduino...", "temp": "0.0"}
    
    try:
        conn = conectar_mysql()
        with conn.cursor() as cursor:
            cursor.execute("SELECT * FROM leituras")
            linhas = cursor.fetchall()
            
            # Garante que funciona mesmo se o banco estiver vazio no início
            if linhas:
                linhas_invertidas = list(linhas)[::-1][:10]
                contador = 1
                for r in linhas_invertidas:
                    # Pega qualquer variação de nome de coluna de temperatura de forma segura
                    temp_valor = r.get('temperatura', r.get('valor', 0.0))
                    data_valor = str(r.get('data_hora', r.get('data', 'Agora')))
                    
                    historico.append({
                        "id": contador, 
                        "sensor": 'DHT11_LOCAL_PORT', 
                        "temp": f"{float(temp_valor):.2f}" if temp_valor else "0.0", 
                        "data": data_valor
                    })
                    contador += 1
        conn.close()
        
        if len(historico) > 0:
            ultima_leitura = {"sensor": historico[0]["sensor"], "temp": historico[0]["temp"]}
            
    except Exception as e: 
        print(f"Erro no painel: {e}")
        
    return render_template_string(
        TEMPLATEDASHBOARD, 
        usuario=session.get('usuario', 'Desconhecido'), 
        cargo=session.get('regime', 'Visitante'), 
        ultima=ultima_leitura, 
        historico=historico
    )

