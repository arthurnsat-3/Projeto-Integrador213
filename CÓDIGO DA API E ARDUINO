BAUD_RATE = 115200

# ===================================================
#          CONEXÃO NATIVA COM O MYSQL
# ===================================================
def conectar_mysql():
    return pymysql.connect(
        host='localhost',
        user='root',          
        password='root',      
        database='alphatech_db',
        charset='utf8mb4',
        cursorclass=pymysql.cursors.DictCursor
    )

# ===================================================
#     THREAD INTELIGENTE QUE PROCURA O ARDUINO
# ===================================================
def escutar_leitura_serial():
    portas_para_testar = ['COM7', 'COM8', 'COM3', 'COM4']
    
    while True:
        ser = None
        porta_ativa = None
        
        for porta in portas_para_testar:
            try:
                ser = serial.Serial(porta, BAUD_RATE, timeout=1)
                porta_ativa = porta
                break 
            except Exception:
                continue 
        
        if ser and porta_ativa:
            print(f"[SERIAL] Conexão estabelecida com sucesso na porta {porta_ativa}! Lendo dados...")
            try:
                while True:
                    if ser.in_waiting > 0:
                        linha = ser.readline().decode('utf-8', errors='ignore').strip()
                        if len(linha) > 0:
                            # Filtra apenas os números da leitura do Arduino
                            linha_limpa = ''.join(c for c in linha if c.isdigit() or c == '.')
                            try:
                                valor_temperatura = float(linha_limpa)
                                print(f"[DADO USB] Temperatura recebida ({porta_ativa}): {valor_temperatura}°C")
                                
                                agora = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
                                
                                conn = conectar_mysql()
                                with conn.cursor() as cursor:
                                    # Gravação direta usando colunas padrão
                                    sql = "INSERT INTO leituras (id_sensor, temperatura, data_hora) VALUES (%s, %s, %s)"
                                    cursor.execute(sql, (1, valor_temperatura, agora))
                                    conn.commit()
                                conn.close()
                            except ValueError:
                                pass
                    time.sleep(0.1)
            except Exception:
                print(f"[AVISO HARDWARE] Conexão perdida na porta {porta_ativa}. Buscando novamente...")
            finally:
                if ser:
                    ser.close()
        else:
            print("[AVISO HARDWARE] Nenhuma placa encontrada. Certifique-se de FECHAR O MONITOR SERIAL DA IDE DO ARDUINO! Tentando em 3s...")
            time.sleep(3)

